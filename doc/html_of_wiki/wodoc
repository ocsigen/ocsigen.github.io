;; Declarative wodoc config for the html_of_wiki documentation.
;; html_of_wiki (legacy wikicreole site generator, superseded by wodoc) exposes
;; no public library API, so there is no `dune build @doc`. Its doc is a single
;; self-describing manual page, converted once to mld/index.mld (the legacy repo
;; is untouched) and built straight with odoc (mld-dir). The in-page anchor menu
;; drives the left nav (anchor-menu); the first content straddles odoc's preamble
;; boundary, hence (flat).
(project html_of_wiki)
(title html_of_wiki)
(url-prefix /html_of_wiki)
(css /css/style.css /css/ocsigen-odoc.css)  ; shared Ocsigen theme (wodoc css default changed)
(mld-dir mld)
(mld-package html_of_wiki)
(flat)
(anchor-menu menu.wiki)
(highlight how-highlight.js)
(landing index.html)
