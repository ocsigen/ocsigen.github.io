# Generated per-version doc output (rebuilt by each project's build.sh),
# including the `latest` symlink that points at the newest version dir.
/wodoc/ocsigenserver/*/
/wodoc/eliom/*/
/wodoc/eliom/latest
/wodoc/ocsigenserver/latest
/wodoc/ocsigen-toolkit/*/
/wodoc/ocsigen-toolkit/latest
/wodoc/ocsigen-start/*/
/wodoc/ocsigen-start/latest
/wodoc/ocsigen-i18n/*/
/wodoc/ocsigen-i18n/latest
# ocsimore is single-version + frozen; ignore only the generated version dir and
# symlink (mld/ and api-snapshot/ are tracked sources, not generated).
/wodoc/ocsimore/0.5/
/wodoc/ocsimore/latest
/wodoc/tuto/*/
/wodoc/tuto/latest
